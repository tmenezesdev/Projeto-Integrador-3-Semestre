# =========================================================================
# EXEMPLO de variáveis de ambiente — copie para um arquivo .env e preencha.
# NUNCA coloque segredos reais neste arquivo (ele é versionado no git).
# O .env real está no .gitignore e não deve ser commitado.
# =========================================================================

# Configurações do Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=SmartBench_DB

# Configurações do Servidor
PORT=3000
NODE_ENV=development

# Origens permitidas no CORS (separadas por vírgula). Vazio = '*'
CORS_ORIGIN=

# Configurações JWT — gere um segredo forte, ex.: openssl rand -hex 64
JWT_SECRET=coloque_um_segredo_forte_aqui
JWT_EXPIRES_IN=1h

# Configurações de Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif

# Configurações de Paginação
PAGINACAO_LIMITE_PADRAO=10
PAGINACAO_LIMITE_MAXIMO=100

# Cloudinary (armazenamento de imagens)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# E-mail (Brevo) — usado no reset de senha
BREVO_API_KEY=sua_brevo_api_key
FRONTEND_URL=http://localhost:3001

# Configurações do IoT (agente serial local — `npm run bridge`)
PORTA_SERIAL=COM3
BAUD_SERIAL=115200      # deve bater com o firmware Espruino (console padrão do ESP32)
IOT_SERIAL_ENABLED=true # use false para desligar a leitura serial do agente

# Para onde o agente local empurra os eventos (backend na nuvem):
API_URL=https://projeto-integrador-3-semestre-production-197e.up.railway.app
# Segredo compartilhado entre o agente e o backend (defina o MESMO valor na Railway).
# Se ficar vazio, o ingest fica ABERTO (sem autenticação).
IOT_INGEST_TOKEN=
