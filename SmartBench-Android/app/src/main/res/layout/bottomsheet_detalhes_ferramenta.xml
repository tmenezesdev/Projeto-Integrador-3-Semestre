<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/bgSecondary"
    android:orientation="vertical"
    android:padding="@dimen/margin_large">

    <View android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal" android:layout_marginBottom="@dimen/margin_medium"
        android:background="@color/border_light" />

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Detalhes da Ferramenta" android:textColor="@color/text_primary"
        android:textSize="@dimen/text_large" android:textStyle="bold"
        android:layout_marginBottom="@dimen/margin_medium" />

    <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginBottom="@dimen/margin_medium"
        app:cardBackgroundColor="?attr/bgCard" app:cardCornerRadius="@dimen/card_corner_radius"
        app:strokeColor="?attr/colorPrimary" app:strokeWidth="1dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="@dimen/margin_medium">

            <TextView android:id="@+id/tvNome" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_primary"
                android:textStyle="bold" android:textSize="@dimen/text_medium" />

            <TextView android:id="@+id/tvTag" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_muted"
                android:textSize="@dimen/text_small" android:fontFamily="monospace"
                android:layout_marginBottom="@dimen/margin_small" />

            <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_body" android:textStyle="bold"
                android:layout_marginBottom="@dimen/margin_small" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Responsável:" android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_small" />
            <TextView android:id="@+id/tvResponsavel" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" android:layout_marginBottom="@dimen/margin_small" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hora de retirada:" android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_small" />
            <TextView android:id="@+id/tvHoraRetirada" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" android:layout_marginBottom="@dimen/margin_small" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tempo fora:" android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_small" />
            <TextView android:id="@+id/tvTempoFora" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="?attr/colorPrimary"
                android:textSize="20sp" android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton android:id="@+id/btnFechar"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Fechar" />
</LinearLayout>
