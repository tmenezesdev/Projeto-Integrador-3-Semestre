<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@color/bg_primary" android:orientation="vertical"
        android:clipToPadding="false" android:paddingBottom="80dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Minhas Retiradas" android:textColor="@color/text_primary"
            android:textSize="@dimen/text_title" android:textStyle="bold"
            android:padding="@dimen/margin_medium" />

        <TextView android:id="@+id/tvVazio"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Nenhuma ferramenta retirada no momento"
            android:textColor="@color/text_muted" android:textSize="@dimen/text_medium"
            android:gravity="center" android:padding="@dimen/margin_xlarge"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvRetiradas"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:clipToPadding="false" android:paddingHorizontal="@dimen/margin_medium" />

    </LinearLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
