<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
   
    android:clipToPadding="false"
    android:paddingBottom="80dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="@dimen/margin_medium">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/epi_titulo" android:textColor="@color/text_primary"
            android:textSize="@dimen/text_title" android:textStyle="bold"
            android:layout_marginBottom="@dimen/margin_small" />

        <!-- Aviso NR-6 -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="@dimen/margin_medium"
            app:cardBackgroundColor="@color/warning_container"
            app:cardCornerRadius="@dimen/card_corner_radius">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="@dimen/margin_medium">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/epi_nr6" android:textColor="@color/warning"
                    android:textStyle="bold" android:textSize="@dimen/text_body" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="O uso de EPIs é obrigatório por lei. A não utilização pode resultar em acidentes graves e responsabilidade legal."
                    android:textColor="@color/text_secondary" android:textSize="@dimen/text_small"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- EPIs Grid (2 colunas) -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Equipamentos Obrigatórios" android:textColor="@color/text_primary"
            android:textSize="@dimen/text_medium" android:textStyle="bold"
            android:layout_marginBottom="@dimen/margin_small" />

        <!-- EPI 1: Capacete -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="@dimen/margin_small">
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="100dp" android:layout_weight="1" android:layout_marginEnd="4dp"
                app:cardBackgroundColor="?attr/bgCard" app:cardCornerRadius="@dimen/card_corner_radius"
                app:strokeColor="?attr/colorPrimary" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_small">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_shield" app:tint="?attr/colorPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Capacete" android:textColor="@color/text_primary"
                        android:textStyle="bold" android:gravity="center" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Proteção craniana" android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_small" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="100dp" android:layout_weight="1" android:layout_marginStart="4dp"
                app:cardBackgroundColor="?attr/bgCard" app:cardCornerRadius="@dimen/card_corner_radius"
                app:strokeColor="?attr/colorPrimary" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_small">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_shield" app:tint="?attr/colorPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Luvas" android:textColor="@color/text_primary"
                        android:textStyle="bold" android:gravity="center" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Proteção das mãos" android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_small" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="@dimen/margin_small">
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="100dp" android:layout_weight="1" android:layout_marginEnd="4dp"
                app:cardBackgroundColor="?attr/bgCard" app:cardCornerRadius="@dimen/card_corner_radius"
                app:strokeColor="?attr/colorPrimary" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_small">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_shield" app:tint="?attr/colorPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Óculos" android:textColor="@color/text_primary"
                        android:textStyle="bold" android:gravity="center" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Proteção ocular" android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_small" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="100dp" android:layout_weight="1" android:layout_marginStart="4dp"
                app:cardBackgroundColor="?attr/bgCard" app:cardCornerRadius="@dimen/card_corner_radius"
                app:strokeColor="?attr/colorPrimary" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_small">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_shield" app:tint="?attr/colorPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Protetor Auricular" android:textColor="@color/text_primary"
                        android:textStyle="bold" android:gravity="center" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Proteção auditiva" android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_small" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="@dimen/margin_medium">
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="100dp" android:layout_weight="1" android:layout_marginEnd="4dp"
                app:cardBackgroundColor="?attr/bgCard" app:cardCornerRadius="@dimen/card_corner_radius"
                app:strokeColor="?attr/colorPrimary" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_small">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_shield" app:tint="?attr/colorPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Botina" android:textColor="@color/text_primary"
                        android:textStyle="bold" android:gravity="center" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Proteção dos pés" android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_small" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="100dp" android:layout_weight="1" android:layout_marginStart="4dp"
                app:cardBackgroundColor="?attr/bgCard" app:cardCornerRadius="@dimen/card_corner_radius"
                app:strokeColor="?attr/colorPrimary" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_small">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_shield" app:tint="?attr/colorPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Avental" android:textColor="@color/text_primary"
                        android:textStyle="bold" android:gravity="center" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Proteção corporal" android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_small" android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Normas de uso -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Normas de Uso" android:textColor="@color/text_primary"
            android:textSize="@dimen/text_medium" android:textStyle="bold"
            android:layout_marginBottom="@dimen/margin_small" />

        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/bgCard" app:cardCornerRadius="@dimen/card_corner_radius"
            app:strokeColor="?attr/colorPrimary" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="@dimen/margin_medium">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✓  Utilizar EPIs antes de iniciar qualquer atividade"
                    android:textColor="@color/text_primary" android:textSize="@dimen/text_body"
                    android:layout_marginBottom="@dimen/margin_small" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✓  Inspecionar o equipamento antes do uso"
                    android:textColor="@color/text_primary" android:textSize="@dimen/text_body"
                    android:layout_marginBottom="@dimen/margin_small" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✓  Não emprestar ou compartilhar sem higienização"
                    android:textColor="@color/text_primary" android:textSize="@dimen/text_body"
                    android:layout_marginBottom="@dimen/margin_small" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✓  Comunicar imediatamente se danificado ou extraviado"
                    android:textColor="@color/text_primary" android:textSize="@dimen/text_body" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
