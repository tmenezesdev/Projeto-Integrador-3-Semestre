<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_primary"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_medium">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Visão Geral" android:textColor="@color/text_primary"
                android:textSize="@dimen/text_title" android:textStyle="bold"
                android:layout_marginBottom="@dimen/margin_medium" />

            <!-- KPIs linha 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="@dimen/margin_small">

                <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                    android:layout_height="@dimen/kpi_card_height" android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="@dimen/card_corner_radius"
                    app:strokeColor="@color/border_default" app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_small">
                        <TextView android:id="@+id/tvTotalFerramentas" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="?attr/colorPrimary" android:textSize="@dimen/text_kpi" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total" android:textColor="@color/text_secondary" android:textSize="@dimen/text_small" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                    android:layout_height="@dimen/kpi_card_height" android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="@dimen/card_corner_radius"
                    app:strokeColor="@color/border_default" app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_small">
                        <TextView android:id="@+id/tvEmUso" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="?attr/colorPrimary" android:textSize="@dimen/text_kpi" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Em Uso" android:textColor="@color/text_secondary" android:textSize="@dimen/text_small" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- KPIs linha 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="@dimen/margin_small">

                <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                    android:layout_height="@dimen/kpi_card_height" android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="@dimen/card_corner_radius"
                    app:strokeColor="@color/border_default" app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_small">
                        <TextView android:id="@+id/tvAtrasadas" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="@color/status_ativo" android:textSize="@dimen/text_kpi" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Atrasadas" android:textColor="@color/text_secondary" android:textSize="@dimen/text_small" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                    android:layout_height="@dimen/kpi_card_height" android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="@dimen/card_corner_radius"
                    app:strokeColor="@color/border_default" app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_small">
                        <TextView android:id="@+id/tvAlertasAtivos" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="@color/status_ativo" android:textSize="@dimen/text_kpi" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Alertas" android:textColor="@color/text_secondary" android:textSize="@dimen/text_small" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- KPIs linha 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="@dimen/margin_medium">

                <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                    android:layout_height="@dimen/kpi_card_height" android:layout_weight="1" android:layout_marginEnd="4dp"
                    app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="@dimen/card_corner_radius"
                    app:strokeColor="@color/border_default" app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_small">
                        <TextView android:id="@+id/tvTransacoesHoje" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="?attr/colorPrimary" android:textSize="@dimen/text_kpi" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Transações Hoje" android:textColor="@color/text_secondary" android:textSize="@dimen/text_small" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                    android:layout_height="@dimen/kpi_card_height" android:layout_weight="1" android:layout_marginStart="4dp"
                    app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="@dimen/card_corner_radius"
                    app:strokeColor="@color/border_default" app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="@dimen/margin_small">
                        <TextView android:id="@+id/tvMecanicosAtivos" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="?attr/colorPrimary" android:textSize="@dimen/text_kpi" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Mecânicos Ativos" android:textColor="@color/text_secondary" android:textSize="@dimen/text_small" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Taxa no Prazo -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="@dimen/card_corner_radius"
                app:strokeColor="@color/border_default" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center" android:orientation="vertical" android:padding="@dimen/margin_medium">
                    <TextView android:id="@+id/tvTaxaPrazo"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--%" android:textColor="@color/status_disponivel"
                        android:textSize="36sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Taxa no Prazo" android:textColor="@color/text_secondary" android:textSize="@dimen/text_body"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Gráfico -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="@dimen/card_corner_radius"
                app:strokeColor="@color/border_default" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="@dimen/margin_medium">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Fluxo de Movimentações" android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_medium" android:textStyle="bold" android:layout_marginBottom="@dimen/margin_small" />
                    <com.google.android.material.chip.ChipGroup android:id="@+id/chipGroupPeriodo"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        app:selectionRequired="true" app:singleSelection="true"
                        android:layout_marginBottom="@dimen/margin_small">
                        <com.google.android.material.chip.Chip android:id="@+id/chip7d"
                            style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="@string/periodo_7d" android:checked="true" />
                        <com.google.android.material.chip.Chip android:id="@+id/chip15d"
                            style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="@string/periodo_15d" />
                        <com.google.android.material.chip.Chip android:id="@+id/chip90d"
                            style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="@string/periodo_90d" />
                    </com.google.android.material.chip.ChipGroup>
                    <com.github.mikephil.charting.charts.LineChart android:id="@+id/chartFluxo"
                        android:layout_width="match_parent" android:layout_height="200dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Ferramentas Fora -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="@dimen/card_corner_radius"
                app:strokeColor="@color/border_default" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="@dimen/margin_medium">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ferramentas Fora Agora" android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_medium" android:textStyle="bold" android:layout_marginBottom="@dimen/margin_small" />
                    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvFerramentasFora"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
