<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
       
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_medium">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_title"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/margin_medium" />

            <!-- KPIs Linha 1: 2 cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/margin_small">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTotalFerramentas"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/kpi_card_height"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardBackgroundColor="?attr/bgCard"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:strokeColor="?attr/colorPrimary"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/margin_small">
                        <TextView android:id="@+id/tvTotalFerramentas"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--" android:textColor="?attr/colorPrimary"
                            android:textSize="@dimen/text_kpi" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_total_ferramentas" android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_small" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTotalUsuarios"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/kpi_card_height"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:cardBackgroundColor="?attr/bgCard"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:strokeColor="?attr/colorPrimary"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/margin_small">
                        <TextView android:id="@+id/tvTotalUsuarios"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--" android:textColor="?attr/colorPrimary"
                            android:textSize="@dimen/text_kpi" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_total_usuarios" android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_small" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- KPIs Linha 2: 2 cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/margin_medium">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTransacoesHoje"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/kpi_card_height"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardBackgroundColor="?attr/bgCard"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:strokeColor="?attr/colorPrimary"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/margin_small">
                        <TextView android:id="@+id/tvTransacoesHoje"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--" android:textColor="?attr/colorPrimary"
                            android:textSize="@dimen/text_kpi" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_transacoes_hoje" android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_small" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAlertasAtivos"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/kpi_card_height"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:cardBackgroundColor="?attr/bgCard"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:strokeColor="?attr/colorPrimary"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/margin_small">
                        <TextView android:id="@+id/tvAlertasAtivos"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--" android:textColor="@color/status_ativo"
                            android:textSize="@dimen/text_kpi" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_alertas_ativos" android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_small" android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Gráfico de Fluxo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="?attr/bgCard"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/margin_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fluxo de Movimentações"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/margin_small" />

                    <!-- Filtros de período -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupPeriodo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:selectionRequired="true"
                        app:singleSelection="true"
                        android:layout_marginBottom="@dimen/margin_small">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip7d"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/periodo_7d"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip15d"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/periodo_15d" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip90d"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/periodo_90d" />
                    </com.google.android.material.chip.ChipGroup>

                    <!-- LineChart MPAndroidChart -->
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartFluxo"
                        android:layout_width="match_parent"
                        android:layout_height="200dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Atividade Recente -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="?attr/bgCard"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/margin_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_atividade_recente"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/margin_small" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvAtividadeRecente"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
